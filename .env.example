# =============================================================================
# Parakeet-RS WebRTC Transcriber - Configuration
# =============================================================================
# Copy this file to .env and modify as needed
#
# BUILD COMMAND:
#   cargo build --release --bin parakeet-server --features "server,sortformer"
#
# With CUDA GPU support:
#   cargo build --release --bin parakeet-server --features "server,sortformer,cuda"

# =============================================================================
# GPU Configuration
# =============================================================================

# Enable GPU acceleration for inference
# Values: cuda, tensorrt, or leave empty/false for CPU
USE_GPU=

# ONNX Runtime library path
# CPU:  ORT_DYLIB_PATH=./ort-cpu/libonnxruntime.so
# GPU:  ORT_DYLIB_PATH=./ort-gpu/libonnxruntime.so
ORT_DYLIB_PATH=./ort-cpu/libonnxruntime.so

# ONNX Runtime thread configuration
# For CPU-only: INTRA_THREADS=4-8, INTER_THREADS=1
# For GPU: INTRA_THREADS=2, INTER_THREADS=1
INTRA_THREADS=4
INTER_THREADS=1

# =============================================================================
# Model Paths
# =============================================================================

# Parakeet TDT model directory (English ASR - fast, accurate)
TDT_MODEL_PATH=./tdt

# Canary 1B model directory (Multilingual ASR: en, de, fr, es)
CANARY_MODEL_PATH=./canary

# Diarization model - SortFormer (speaker identification, up to 4 speakers)
DIAR_MODEL_PATH=./diar_streaming_sortformer_4spk-v2.onnx

# =============================================================================
# Server Configuration
# =============================================================================

# HTTP/WebSocket server port
PORT=8080

# Maximum concurrent transcription sessions
MAX_CONCURRENT_SESSIONS=10

# =============================================================================
# Media Files
# =============================================================================

# Directory for uploaded/stored audio files
MEDIA_DIR=./media

# =============================================================================
# Frontend
# =============================================================================

# Path to frontend static files
FRONTEND_PATH=./frontend

# =============================================================================
# WebRTC / ICE Configuration
# =============================================================================

# Public IP for WebRTC ICE candidates (required for NAT traversal)
PUBLIC_IP=

# WebSocket host override (optional)
# Priority: WS_HOST > PUBLIC_IP > auto-detected
WS_HOST=

# TURN server for NAT traversal (optional)
# TURN_SERVER=turn:your-turn-server:3478
# TURN_USERNAME=user
# TURN_PASSWORD=pass

# COTURN ephemeral credentials (shared secret mode)
# When set, overrides static TURN_USERNAME/TURN_PASSWORD
# TURN_SHARED_SECRET=

# Force TURN relay mode (use when direct/STUN connectivity fails)
FORCE_RELAY=false

# =============================================================================
# SRT Live Streams (optional)
# =============================================================================

# IP address of the SRT encoder/source
# SRT_ENCODER_IP=

# JSON array of SRT channels
# SRT_CHANNELS=[{"name":"Channel1","port":"24001"}]

# =============================================================================
# FAB Live Transcription Forwarding (optional)
# =============================================================================

# FAB endpoint URL for live transcription forwarding
# FAB_URL=http://example.com/livetranscription/send
# FAB_ENABLED=false
# FAB_SEND_TYPE=growing

# =============================================================================
# Transcription Modes
# =============================================================================
# Modes are selected per-session via the API/frontend:
#   speedy           - Best balance of latency and quality (~0.3-1.5s)
#   growing_segments - Word-by-word PARTIAL updates building toward FINAL sentences
#   pause_segmented  - Segment by acoustic pauses, transcribe each chunk once
#
# Models:
#   parakeet-tdt - English only, fast (all 3 modes)
#   canary-1b    - Multilingual: en, de, fr, es (all 3 modes)
